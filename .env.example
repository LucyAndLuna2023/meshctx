OPENAI_API_KEY=sk-
ANTHROPIC_API_KEY=sk-
GEMINI_API_KEY=
XAI_API_KEY=
TOGETHER_API_KEY=
MISTRAL_API_KEY=
COHERE_API_KEY=
GROQ_API_KEY=
PERPLEXITY_API_KEY=
OPENROUTER_API_KEY=

# ═══ China Providers ═══
BAILIAN_API_KEY=sk-
ZHIPU_API_KEY=
MOONSHOT_API_KEY=
DOUBAO_API_KEY=
HUNYUAN_API_KEY=
SPARK_API_KEY=
YI_API_KEY=
